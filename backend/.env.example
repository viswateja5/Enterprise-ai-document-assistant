# Dynamic Model Provider Configuration (supported: openai, gemini, groq, ollama)
MODEL_PROVIDER=openai

# Model Provider API Credentials
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_gemini_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Tavily Web Search API Credentials (required for search fallback)
TAVILY_API_KEY=your_tavily_search_api_key_here

# JWT Authentication Configuration
# Generate a secure random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=98782a8fb3a24564c76b9116e045cb2119ef0052baae9893d9ce1cf0f80bb150
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database Configuration
# Fallback to local SQLite is used if blank or configured as below:
DATABASE_URL=sqlite+aiosqlite:///vector_store/chat_history.db
# For production PostgreSQL container (uncomment to override):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_assistant

# Redis Caching Configuration
REDIS_URL=redis://redis:6379/0
